#Main provider and model
PROVIDER=anthropic
CLAUDE_MODEL=claude-sonnet-4-6

#Fallback provider and model
FALLBACK_PROVIDER=openrouter
FALLBACK_MODEL=stepfun/step-3.5-flash:free
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

#Telegram bot token
TAU_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_OWNER_ID="YOUR_TELEGRAM_OWNER_ID"

#Auto-push (agent creates .autopush file to trigger)
AUTO_PUSH=true
GITHUB_TOKEN="YOUR_GITHUB_TOKEN" #https://github.com/settings/personal-access-tokens
