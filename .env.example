# Main provider and model
PROVIDER=anthropic
CLAUDE_MODEL=claude-sonnet-4-6

# OPENCODE (config from .env — opencode.json optional)
FALLBACK_PROVIDER=opencode
FALLBACK_MODEL=minimax-m2.5-free
OPENCODE_API_KEY="YOUR_OPENCODE_API_KEY"
#OPENCODE_AUTOUPDATE=false
#OPENCODE_SNAPSHOT=false
    
# OPENROUTER
#FALLBACK_PROVIDER=openrouter
#FALLBACK_MODEL=stepfun/step-3.5-flash:free
#OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

#Telegram bot token
TAU_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_OWNER_ID="YOUR_TELEGRAM_OWNER_ID"

#Auto-push profitable changes to GitHub
AUTO_PUSH=true
#https://github.com/settings/personal-access-tokens
GITHUB_TOKEN="YOUR_GITHUB_TOKEN"

